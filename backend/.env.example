# LIFEASY V30 PRO - Production Environment Configuration
# Copy this to .env and update with your production credentials

# ============================================
# 🚀 ENVIRONMENT SETTINGS
# ============================================
LIFEASY_ENV=production
DEBUG=False

# ============================================
# 🔒 SECURITY KEYS (CHANGE THESE IN PRODUCTION!)
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2026
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# 💾 DATABASE CONFIGURATION
# ============================================
# PostgreSQL (Production)
DATABASE_URL=postgresql://lifeasy_user:your_password@your_host:5432/lifeasy_db

# For Render.com (example):
# DATABASE_URL=postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/dbname?sslmode=require

# ============================================
# 📱 SMS/OTP SERVICE - TWILIO
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: SSL Wireless (Bangladesh)
SSL_WIRELESS_API_KEY=your_ssl_wireless_api_key
SSL_WIRELESS_SENDER_ID=LIFEASY

# ============================================
# 💳 PAYMENT GATEWAY - BKASH/NAGAD
# ============================================
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://checkout.sandbox.bka.sh/v1.2.0-beta  # Change to production URL

NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_API_KEY=your_nagad_api_key
NAGAD_BASE_URL=https://api.sandbox.nagad-payment.com  # Change to production URL

# ============================================
# 🔔 FIREBASE CLOUD MESSAGING
# ============================================
FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json
FIREBASE_PROJECT_ID=your_project_id

# ============================================
# 🌐 SERVER CONFIGURATION
# ============================================
HOST=0.0.0.0
PORT=${PORT:-8000}
WORKERS=4

# ============================================
# CORS SETTINGS (Update for production)
# ============================================
ALLOWED_ORIGINS=http://localhost:8000,https://api.lifeasy.com,https://lifeasy.com
CORS_ALLOW_ALL=False  # Set to False in production

# ============================================
# TOKEN SETTINGS
# ============================================
TOKEN_EXPIRY=43200  # 30 days in minutes
OTP_EXPIRY=300  # 5 minutes in seconds

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
